# LineaDAT Frontend Environment Configuration
#
# Copy to `.env.local` and fill in after Phase 3 redeploy completes.
# All vars prefixed with NEXT_PUBLIC_ are exposed to the browser.
#
# After Step 7 (LineaDAT contracts redeploy), the contract address values
# below will change but the variable names stay the same.

# Network configuration
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_CHAIN_NAME="Base Sepolia"
NEXT_PUBLIC_RPC_URL=https://base-sepolia.drpc.org
NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://sepolia.basescan.org

# Contract addresses (filled in after `forge script DeployBaseSepolia` completes).
# tLINEA stays the same across LINEASTR -> LineaDAT redeploy (we do NOT redeploy tLINEA).
# All other addresses change when Step 7 redeploys the LineaDAT contracts.
NEXT_PUBLIC_TLINEA_ADDRESS=
NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_STRATEGY_ADDRESS=
NEXT_PUBLIC_BOT_ADDRESS=
NEXT_PUBLIC_HOOK_ADDRESS=
NEXT_PUBLIC_SWAPPER_ADDRESS=
NEXT_PUBLIC_DEPLOY_BLOCK=
NEXT_PUBLIC_INDEXER_URL=https://lineastr-indexer.fly.dev/graphql

# WalletConnect (https://cloud.walletconnect.com/) — get a project ID for production
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_WC_PROJECT_ID
